# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# API
EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your_revenuecat_ios_key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your_revenuecat_android_key

# Google AdMob
EXPO_PUBLIC_ADMOB_BANNER_ID=ca-app-pub-xxxxxxxxxxxxx/xxxxxxxxxxx
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-xxxxxxxxxxxxx/xxxxxxxxxxx
