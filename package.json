{
  "name": "expo-boilerplate",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "test": "jest --watchAll",
    "prebuild": "expo prebuild --clean",
    "prebuild:clean": "expo prebuild --clean",
    "rename": "node rename-app.js"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-router": "~6.0.0",
    "expo-status-bar": "~2.2.0",
    "expo-constants": "~18.0.0",
    "expo-linking": "~8.0.0",
    "expo-splash-screen": "~0.31.0",
    "expo-font": "~14.0.0",
    "expo-localization": "~16.1.0",
    "expo-secure-store": "~14.1.0",
    "expo-dev-client": "~5.1.0",
    "react": "19.1.0",
    "react-native": "0.81.0",
    "react-native-screens": "~4.16.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-reanimated": "~3.17.0",
    "react-native-gesture-handler": "~2.28.0",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "nativewind": "^4.2.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.12",
    "@tanstack/react-query": "^5.91.0",
    "axios": "^1.7.9",
    "i18next": "^24.2.3",
    "react-i18next": "^15.4.1",
    "react-native-purchases": "^9.14.0",
    "react-native-google-mobile-ads": "^16.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "@types/react": "~19.0.0",
    "@types/react-native": "~0.81.0",
    "typescript": "^5.3.3",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~9.0.0",
    "prettier": "^3.4.2",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "@testing-library/react-native": "^12.8.1"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|nativewind)"
    ]
  }
}
